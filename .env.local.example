APP_NAME=delivery-platform
APP_ENV=local
APP_PORT=18080
APP_VERSION=local-test
RELEASE_ID=local-test
DOMAIN=delivery-platform.localhost
API_BASE_URL=http://delivery-platform.localhost:18080/api/v1

FRONTEND_PORT=18080
BACKEND_PORT=13000
MYSQL_PORT=13306
REDIS_PORT=16379
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001

MYSQL_ROOT_PASSWORD=CHANGE_ME_LOCAL_MYSQL_ROOT_PASSWORD
MYSQL_DATABASE=delivery_platform
MYSQL_USER=delivery_user
MYSQL_USER_PASSWORD=CHANGE_ME_LOCAL_MYSQL_USER_PASSWORD

REDIS_PASSWORD=CHANGE_ME_LOCAL_REDIS_PASSWORD

MINIO_ROOT_USER=delivery_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_LOCAL_MINIO_PASSWORD
MINIO_BUCKET=delivery-platform
MINIO_IMAGE=quay.io/minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=quay.io/minio/mc:RELEASE.2025-07-21T05-28-08Z

CORS_ORIGIN=http://delivery-platform.localhost:18080

DATABASE_URL=mysql://delivery_user:CHANGE_ME_LOCAL_MYSQL_USER_PASSWORD@mysql:3306/delivery_platform
REDIS_URL=redis://:CHANGE_ME_LOCAL_REDIS_PASSWORD@redis:6379
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_WITH_AT_LEAST_32_CHARACTERS
JWT_EXPIRES_IN=8h

SEED_ADMIN_PASSWORD=CHANGE_ME_LOCAL_ADMIN_PASSWORD
SEED_DEFAULT_PASSWORD=CHANGE_ME_LOCAL_DEMO_USER_PASSWORD
