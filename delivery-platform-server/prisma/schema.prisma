model ApprovalTemplate {
  id           String    @id @default(uuid())
  templateCode String    @unique @map("template_code") @db.VarChar(50)
  templateName String    @map("template_name") @db.VarChar(100)
  businessType String    @map("business_type") @db.VarChar(50)
  countryCode  String?   @map("country_code") @db.VarChar(10)
  isEnabled    Boolean   @default(true) @map("is_enabled")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  steps ApprovalStep[]
  tasks ApprovalTask[]

  @@index([businessType, isEnabled])
  @@index([deletedAt])
  @@map("approval_templates")
}

model ApprovalStep {
  id             String   @id @default(uuid())
  templateId     String   @map("template_id") @db.VarChar(36)
  stepOrder      Int      @map("step_order")
  stepName       String   @map("step_name") @db.VarChar(100)
  mode           String   @default("SINGLE") @db.VarChar(20)
  requiredCount  Int      @default(1) @map("required_count")
  approverType   String   @map("approver_type") @db.VarChar(30)
  approverValues Json     @map("approver_values")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  template ApprovalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, stepOrder])
  @@map("approval_steps")
}

model ApprovalTask {
  id            String    @id @default(uuid())
  templateId    String    @map("template_id") @db.VarChar(36)
  businessType  String    @map("business_type") @db.VarChar(50)
  businessId    String    @map("business_id") @db.VarChar(36)
  businessTitle String?   @map("business_title") @db.VarChar(200)
  applicantId   String    @map("applicant_id") @db.VarChar(36)
  currentStep   Int       @default(1) @map("current_step")
  approverId    String?   @map("approver_id") @db.VarChar(36)
  status        String    @default("Pending") @db.VarChar(20)
  comment       String?   @db.VarChar(500)
  decidedAt     DateTime? @map("decided_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  template  ApprovalTemplate @relation(fields: [templateId], references: [id])
  applicant User             @relation("ApprovalTaskApplicant", fields: [applicantId], references: [id])
  approver  User?            @relation("ApprovalTaskApprover", fields: [approverId], references: [id])
  actions   ApprovalAction[]

  @@index([businessType, businessId])
  @@index([approverId, status])
  @@map("approval_tasks")
}

model ApprovalAction {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id") @db.VarChar(36)
  stepOrder Int      @map("step_order")
  action    String   @db.VarChar(30)
  actorId   String   @map("actor_id") @db.VarChar(36)
  comment   String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  task  ApprovalTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User         @relation(fields: [actorId], references: [id])

  @@index([taskId, createdAt])
  @@map("approval_actions")
}

model SkillDefinition {
  id          String   @id @default(uuid())
  skillCode   String   @unique @map("skill_code") @db.VarChar(50)
