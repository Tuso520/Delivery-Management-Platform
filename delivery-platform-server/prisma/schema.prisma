model DailyReport {
  id              String    @id @default(uuid())
  projectId       String    @map("project_id") @db.VarChar(36)
  authorId        String    @map("author_id") @db.VarChar(36)
  reportType      String    @map("report_type") @db.VarChar(20) // daily/weekly/monthly
  reportDate      DateTime  @map("report_date")
  content         String    @db.Text
  workHours       Decimal?  @map("work_hours") @db.Decimal(5, 1)
  projectProgress String?   @map("project_progress") @db.VarChar(500)
  paymentProgress String?   @map("payment_progress") @db.VarChar(500)
  riskNotes       String?   @map("risk_notes") @db.Text
  nextPlan        String?   @map("next_plan") @db.Text
  status          String    @default("Draft") @db.VarChar(20) // Draft/Submitted/Reviewed
  reviewedBy      String?   @map("reviewed_by") @db.VarChar(36)
  reviewedAt      DateTime? @map("reviewed_at")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  project  Project @relation(fields: [projectId], references: [id])
  author   User    @relation(fields: [authorId], references: [id])
  reviewer User?   @relation("ReportReviewer", fields: [reviewedBy], references: [id])

  @@index([projectId, reportType])
  @@index([authorId, reportDate])
  @@index([reportDate])
  @@index([deletedAt])
  @@index([projectId, reportDate, status])
  @@map("daily_reports")
}

