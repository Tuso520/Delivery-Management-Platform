model OkrObjective {
  id              String   @id @default(uuid())
  title           String   @db.VarChar(200)
  description     String?  @db.Text
  period          String   @db.VarChar(20) // Q1/Q2/Q3/Q4
  periodType      String   @map("period_type") @db.VarChar(20) // quarterly/yearly/monthly
  ownerId         String   @map("owner_id") @db.VarChar(36)
  departmentId    String?  @map("department_id") @db.VarChar(36)
  weight          Int      @default(100)
  progress        Int      @default(0) // 0-100
  goalType        String   @default("OKR") @map("goal_type") @db.VarChar(20)
  scoringFlow     String   @default("Manager") @map("scoring_flow") @db.VarChar(30)
  scoringMethod   String   @default("Weighted") @map("scoring_method") @db.VarChar(30)
  scorerIds       Json?    @map("scorer_ids")
  scoringContent  Json?    @map("scoring_content")
  calculationRule String?  @map("calculation_rule") @db.VarChar(500)
  status          String   @default("Active") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  owner      User               @relation(fields: [ownerId], references: [id])
  keyResults KeyResult[]
  scores     PerformanceScore[]

  @@index([ownerId, period])
  @@map("okr_objectives")
}

model KeyResult {
  id           String   @id @default(uuid())
  objectiveId  String   @map("objective_id") @db.VarChar(36)
  title        String   @db.VarChar(200)
  targetValue  String?  @map("target_value") @db.VarChar(100)
  currentValue String?  @map("current_value") @db.VarChar(100)
  weight       Int      @default(100)
  progress     Int      @default(0)
  status       String   @default("Active") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  objective OkrObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@map("key_results")
}

model PerformanceScore {
  id           String   @id @default(uuid())
  objectiveId  String   @map("objective_id") @db.VarChar(36)
  scorerId     String   @map("scorer_id") @db.VarChar(36) // 打分人(主管)
  month        String   @db.VarChar(7) // 2026-06
  selfScore    Int?     @map("self_score") // 自评 0-100
  managerScore Int?     @map("manager_score") // 主管打分
  projectRatio String?  @map("project_ratio") @db.Text // 项目占比 JSON
  comment      String?  @db.Text
  nextGoal     String?  @map("next_goal") @db.Text // 下月目标
  status       String   @default("Draft") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  objective OkrObjective @relation(fields: [objectiveId], references: [id])
  scorer    User         @relation(fields: [scorerId], references: [id])

  @@unique([objectiveId, month, scorerId])
  @@map("performance_scores")
}

