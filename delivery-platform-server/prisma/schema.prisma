model IntegrationConfig {
  id                        String    @id @default(uuid())
  provider                  String    @db.VarChar(50)
  configName                String    @map("config_name") @db.VarChar(100)
  configValue               Json      @map("config_value")
  encryptedConfig           String?   @map("encrypted_config") @db.Text
  isEnabled                 Boolean   @default(false) @map("is_enabled")
  description               String?   @db.VarChar(200)
  contactSyncLeaseOwner     String?   @map("contact_sync_lease_owner") @db.VarChar(100)
  contactSyncLeaseExpiresAt DateTime? @map("contact_sync_lease_expires_at")
  contactSyncRevision       Int       @default(0) @map("contact_sync_revision")
  lastContactSyncAt         DateTime? @map("last_contact_sync_at")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  contactCandidates  ExternalContactCandidate[]
  externalIdentities ExternalIdentity[]
  syncLogs           IntegrationSyncLog[]

  @@index([provider, updatedAt])
  @@index([contactSyncLeaseExpiresAt], map: "integration_configs_contact_sync_lease_expires_idx")
  @@map("integration_configs")
}

model IntegrationSyncLog {
  id                  String    @id @default(uuid()) @db.VarChar(36)
  integrationConfigId String?   @map("integration_config_id") @db.VarChar(36)
  provider            String    @db.VarChar(20)
  action              String    @db.VarChar(40)
  status              String    @db.VarChar(20)
  summary             Json?
  errorReason         String?   @map("error_reason") @db.VarChar(1000)
  requestedBy         String?   @map("requested_by") @db.VarChar(36)
  startedAt           DateTime  @default(now()) @map("started_at")
  completedAt         DateTime? @map("completed_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  integration IntegrationConfig? @relation(fields: [integrationConfigId], references: [id], onDelete: SetNull)
  requester   User?              @relation("IntegrationSyncLogRequester", fields: [requestedBy], references: [id], onDelete: SetNull)

  @@index([provider, createdAt])
  @@index([integrationConfigId, createdAt])
  @@index([requestedBy])
  @@map("integration_sync_logs")
}

enum ExternalContactStatus {
  Pending
  Approved
  Rejected
}

model ExternalIdentity {
  id                  String    @id @default(uuid()) @db.VarChar(36)
  integrationConfigId String    @map("integration_config_id") @db.VarChar(36)
  userId              String    @map("user_id") @db.VarChar(36)
  provider            String    @db.VarChar(20)
  externalUserId      String    @map("external_user_id") @db.VarChar(100)
  identifierType      String    @map("identifier_type") @db.VarChar(30)
  isActive            Boolean   @default(true) @map("is_active")
  userProvisioned     Boolean   @default(false) @map("user_provisioned")
  provisionedAt       DateTime  @default(now()) @map("provisioned_at")
  lastSeenAt          DateTime  @map("last_seen_at")
  deactivatedAt       DateTime? @map("deactivated_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  integrationConfig IntegrationConfig @relation(fields: [integrationConfigId], references: [id], onDelete: Restrict)
  user              User              @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([provider, externalUserId], map: "external_identities_provider_external_user_uq")
  @@index([integrationConfigId, isActive], map: "external_identities_config_active_idx")
  @@index([userId, isActive], map: "external_identities_user_active_idx")
  @@map("external_identities")
}

model ExternalContactCandidate {
  id                  String                @id @default(uuid())
  integrationConfigId String                @map("integration_config_id") @db.VarChar(36)
  provider            String                @db.VarChar(50)
  externalUserId      String                @map("external_user_id") @db.VarChar(100)
  realName            String                @map("real_name") @db.VarChar(100)
  phone               String?               @db.VarChar(30)
  email               String?               @db.VarChar(100)
  gender              String?               @db.VarChar(20)
  avatarUrl           String?               @map("avatar_url") @db.VarChar(500)
  departmentName      String?               @map("department_name") @db.VarChar(200)
  positionNames       Json                  @map("position_names")
  rawPayload          Json                  @map("raw_payload")
  status              ExternalContactStatus @default(Pending)
  reviewedBy          String?               @map("reviewed_by") @db.VarChar(36)
  reviewedAt          DateTime?             @map("reviewed_at")
  approvedUserId      String?               @map("approved_user_id") @db.VarChar(36)
  comment             String?               @db.VarChar(500)
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  integrationConfig IntegrationConfig @relation(fields: [integrationConfigId], references: [id], onDelete: Cascade)
  reviewer          User?             @relation("ExternalContactReviewer", fields: [reviewedBy], references: [id])
  approvedUser      User?             @relation("ExternalContactApprovedUser", fields: [approvedUserId], references: [id])

  @@unique([integrationConfigId, externalUserId])
  @@index([provider, status])
  @@index([status, createdAt])
  @@index([reviewedBy])
  @@index([approvedUserId])
  @@map("external_contact_candidates")
}

model ApiKey {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(100)
  apiKey      String    @unique @map("api_key") @db.VarChar(255)
  permissions Json
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  isEnabled   Boolean   @default(true) @map("is_enabled")
  createdBy   String?   @map("created_by") @db.VarChar(36)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("api_keys")
}

