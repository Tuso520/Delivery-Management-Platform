// ============================================================
// Prisma Schema — 交付管理平台
// Database: MySQL 8.0
// Naming: 表名 snake_case 复数，字段 camelCase + @map snake_case
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 01 — 用户与权限
// ============================================================

model User {
  id                String     @id @default(uuid())
  username          String     @unique @db.VarChar(50)
  password          String     @db.VarChar(255)
  realName          String     @map("real_name") @db.VarChar(50)
  email             String?    @db.VarChar(100)
  phone             String?    @db.VarChar(30)
  departmentId      String?    @map("department_id") @db.VarChar(36)
  status            UserStatus @default(Active)
  permissionVersion Int        @default(1) @map("permission_version")
  lastLoginAt       DateTime?  @map("last_login_at")
  deletedAt         DateTime?  @map("deleted_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  userRoles                  UserRole[]
  projectMembers             ProjectMember[]
  archiveItems               ProjectArchiveItem[]       @relation("ArchiveResponsibleUser")
  reviewItems                ProjectArchiveItem[]       @relation("ArchiveReviewUser")
  ownedArchiveEntries        ProjectArchiveEntry[]      @relation("ProjectArchiveEntryOwner")
  createdLogicalFiles        LogicalFile[]              @relation("LogicalFileCreator")
  createdFileAssets          FileAsset[]                @relation("FileAssetCreator")
  uploadedFileVersions       FileVersion[]              @relation("FileVersionUploader")
  submittedReviewTasks       ReviewTask[]               @relation("ReviewTaskSubmitter")
  reviewAssignments          ReviewAssignee[]           @relation("ReviewAssigneeUser")
  reviewActionEvents         ReviewActionEvent[]        @relation("ReviewActionActor")
  createdStandards           Standard[]                 @relation("StandardCreator")
  updatedStandards           Standard[]                 @relation("StandardUpdater")
  submittedStandardVersions  StandardVersion[]          @relation("StandardVersionSubmitter")
  createdKnowledgeItems      KnowledgeItem[]            @relation("KnowledgeItemCreator")
  updatedKnowledgeItems      KnowledgeItem[]            @relation("KnowledgeItemUpdater")
  createdArchiveTemplates    ArchiveTemplate[]          @relation("ArchiveTemplateCreator")
  updatedArchiveTemplates    ArchiveTemplate[]          @relation("ArchiveTemplateUpdater")
  submittedKnowledgeVersions KnowledgeVersion[]         @relation("KnowledgeVersionSubmitter")
  checklistItems             ProjectChecklistItem[]     @relation("ChecklistResponsibleUser")
  checklistReviews           ProjectChecklistItem[]     @relation("ChecklistReviewUser")
  uploadedFiles              File[]
  fileReviews                FileReview[]
  notifications              Notification[]
  notificationDeliveries     NotificationDelivery[]
  externalIdentities         ExternalIdentity[]
  operationLogs              OperationLog[]
  integrationSyncLogs        IntegrationSyncLog[]       @relation("IntegrationSyncLogRequester")
  knowledgeArticles          KnowledgeArticle[]
  knowledgeReviews           KnowledgeArticle[]         @relation("KnowledgeReviewer")
  dailyReports               DailyReport[]
  dailyReportReviews         DailyReport[]              @relation("ReportReviewer")
  okrObjectives              OkrObjective[]
  performanceScores          PerformanceScore[]
  managedDepartments         Department[]               @relation("DepartmentManager")
  uploadedAttachments        Attachment[]
  knowledgeVersions          KnowledgeArticleVersion[]
  skillAssessments           SkillAssessment[]          @relation("SkillAssessmentUser")
  conductedSkillAssessments  SkillAssessment[]          @relation("SkillAssessmentAssessor")
  trainingParticipants       TrainingParticipant[]
  trainingLed                TrainingPlan[]             @relation("TrainingTrainer")
  processRecords             ProjectProcessRecord[]
  projectPayments            ProjectPayment[]
  retrospectiveActions       RetrospectiveAction[]
  approvalTasks              ApprovalTask[]             @relation("ApprovalTaskApplicant")
  approvalReviews            ApprovalTask[]             @relation("ApprovalTaskApprover")
  approvalActions            ApprovalAction[]
  backupRecords              BackupRecord[]
  externalContactReviews     ExternalContactCandidate[] @relation("ExternalContactReviewer")
  approvedExternalContacts   ExternalContactCandidate[] @relation("ExternalContactApprovedUser")
  refreshSessions            RefreshSession[]

  department Department? @relation(fields: [departmentId], references: [id])

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

enum UserStatus {
  Active
  Inactive
  Locked
}

enum DataScopeType {
  ALL
  DEPARTMENT
  COUNTRY
  OWNED
  PARTICIPATED
  CUSTOM
}

model RefreshSession {
  id           String    @id @default(uuid()) @db.VarChar(36)
  userId       String    @map("user_id") @db.VarChar(36)
  tokenHash    String    @unique @map("token_hash") @db.Char(64)
  familyId     String    @map("family_id") @db.VarChar(36)
  deviceId     String?   @map("device_id") @db.VarChar(100)
  ipAddress    String?   @map("ip_address") @db.VarChar(50)
  userAgent    String?   @map("user_agent") @db.VarChar(500)
  expiresAt    DateTime  @map("expires_at")
  lastUsedAt   DateTime? @map("last_used_at")
  revokedAt    DateTime? @map("revoked_at")
  revokeReason String?   @map("revoke_reason") @db.VarChar(50)
  replacedById String?   @unique @map("replaced_by_id") @db.VarChar(36)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy RefreshSession?  @relation("RefreshSessionRotation", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces   RefreshSession[] @relation("RefreshSessionRotation")

  @@index([userId, revokedAt, expiresAt])
  @@index([familyId])
  @@map("refresh_sessions")
}

model Role {
  id               String        @id @default(uuid())
  roleCode         String        @unique @map("role_code") @db.VarChar(50)
  roleName         String        @map("role_name") @db.VarChar(50)
  description      String?       @db.Text
  status           String        @default("Active") @db.VarChar(20)
  defaultDataScope DataScopeType @default(PARTICIPATED) @map("default_data_scope")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id             String    @id @default(uuid())
  permissionCode String    @unique @map("permission_code") @db.VarChar(100)
  permissionName String    @map("permission_name") @db.VarChar(50)
  resource       String    @db.VarChar(50)
  action         String    @db.VarChar(50)
  description    String?   @db.VarChar(200)
  deprecatedAt   DateTime? @map("deprecated_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@index([deprecatedAt])
  @@map("permissions")
}

model UserRole {
  id          String        @id @default(uuid())
  userId      String        @map("user_id") @db.VarChar(36)
  roleId      String        @map("role_id") @db.VarChar(36)
  dataScope   DataScopeType @default(PARTICIPATED) @map("data_scope")
  scopeConfig Json?         @map("scope_config")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId, dataScope])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String @map("role_id") @db.VarChar(36)
  permissionId String @map("permission_id") @db.VarChar(36)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// 02 — 项目中心
// ============================================================

model Project {
  id                       String    @id @default(uuid())
  projectCode              String    @unique @map("project_code") @db.VarChar(30)
  projectName              String    @map("project_name") @db.VarChar(200)
  shortName                String?   @map("short_name") @db.VarChar(100)
  countryCode              String    @map("country_code") @db.VarChar(10)
  city                     String?   @db.VarChar(100)
  customerName             String?   @map("customer_name") @db.VarChar(200)
  projectType              String?   @map("project_type") @db.VarChar(50)
  contractCurrency         String?   @map("contract_currency") @db.VarChar(10)
  baseCurrency             String?   @map("base_currency") @db.VarChar(10)
  contractAmount           Decimal?  @map("contract_amount") @db.Decimal(18, 2)
  exchangeRate             Decimal?  @map("exchange_rate") @db.Decimal(18, 8)
  convertedAmount          Decimal?  @map("converted_amount") @db.Decimal(18, 2)
  exchangeRateDate         DateTime? @map("exchange_rate_date")
  exchangeRateSource       String?   @map("exchange_rate_source") @db.VarChar(50)
  projectLanguage          String?   @map("project_language") @db.VarChar(10)
  salesOwnerId             String?   @map("sales_owner_id") @db.VarChar(36)
  projectManagerId         String?   @map("project_manager_id") @db.VarChar(36)
  electricLeaderId         String?   @map("electric_leader_id") @db.VarChar(36)
  softwareLeaderId         String?   @map("software_leader_id") @db.VarChar(36)
  purchaseOwnerId          String?   @map("purchase_owner_id") @db.VarChar(36)
  financeOwnerId           String?   @map("finance_owner_id") @db.VarChar(36)
  status                   String    @default("DRAFT") @db.VarChar(20)
  currentStage             String    @default("STARTUP") @map("current_stage") @db.VarChar(30)
  progressPercent          Decimal?  @map("progress_percent") @db.Decimal(5, 2)
  riskLevel                RiskLevel @default(Low) @map("risk_level")
  riskDescription          String?   @map("risk_description") @db.Text
  contractNo               String?   @map("contract_no") @db.VarChar(100)
  contractSignedAt         DateTime? @map("contract_signed_at")
  startDate                DateTime? @map("start_date")
  plannedEndDate           DateTime? @map("planned_end_date")
  actualEndDate            DateTime? @map("actual_end_date")
  expectedAcceptanceAt     DateTime? @map("expected_acceptance_at")
  actualAcceptanceAt       DateTime? @map("actual_acceptance_at")
  archivedAt               DateTime? @map("archived_at")
  archiveTemplateId        String?   @map("archive_template_id") @db.VarChar(36)
  archiveTemplateVersionId String?   @map("archive_template_version_id") @db.VarChar(36)
  createIdempotencyKey     String?   @unique(map: "projects_create_idempotency_key_key") @map("create_idempotency_key") @db.VarChar(100)
  createRequestHash        String?   @map("create_request_hash") @db.Char(64)
  revision                 Int       @default(1)
  createdBy                String?   @map("created_by") @db.VarChar(36)
  deletedAt                DateTime? @map("deleted_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  members                ProjectMember[]
  archiveItems           ProjectArchiveItem[]
  archiveFolders         ProjectArchiveFolder[]
  archiveEntries         ProjectArchiveEntry[]
  archiveFiles           ProjectArchiveFile[]
  reviewTasks            ReviewTask[]
  files                  File[]
  checklistItems         ProjectChecklistItem[]
  dailyReports           DailyReport[]
  attachments            Attachment[]
  retrospectives         ProjectRetrospective[]
  processRecords         ProjectProcessRecord[]
  payments               ProjectPayment[]
  archiveTemplate        ArchiveTemplate?        @relation("ProjectArchiveTemplateSnapshot", fields: [archiveTemplateId], references: [id], onDelete: SetNull)
  archiveTemplateVersion ArchiveTemplateVersion? @relation("ProjectArchiveTemplateVersionSnapshot", fields: [archiveTemplateVersionId], references: [id], onDelete: SetNull)

  @@index([status, deletedAt], map: "projects_status_deleted_at_idx")
  @@index([currentStage], map: "projects_current_stage_idx")
  @@index([expectedAcceptanceAt], map: "projects_expected_acceptance_at_idx")
  @@index([archivedAt], map: "projects_archived_at_idx")
  @@index([archiveTemplateId])
  @@index([archiveTemplateVersionId])
  @@index([countryCode])
  @@index([deletedAt])
  @@index([createdBy])
  @@map("projects")
}

enum RiskLevel {
  Low
  Medium
  High
  Critical
}

model ProjectMember {
  id              String    @id @default(uuid())
  projectId       String    @map("project_id") @db.VarChar(36)
  userId          String    @map("user_id") @db.VarChar(36)
  projectRole     String    @map("project_role") @db.VarChar(50)
  permissionLevel String    @default("Member") @map("permission_level") @db.VarChar(20)
  dataScope       String    @default("PROJECT") @map("data_scope") @db.VarChar(20)
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId, deletedAt], map: "project_members_project_id_deleted_at_idx")
  @@index([userId, deletedAt], map: "project_members_user_id_deleted_at_idx")
  @@map("project_members")
}

model ProjectProcessRecord {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id") @db.VarChar(36)
  title       String    @db.VarChar(200)
  recordType  String    @default("Progress") @map("record_type") @db.VarChar(30)
  stageCode   String?   @map("stage_code") @db.VarChar(30)
  recordDate  DateTime  @map("record_date")
  description String?   @db.Text
  status      String    @default("Recorded") @db.VarChar(20)
  createdBy   String    @map("created_by") @db.VarChar(36)
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])

  @@index([projectId, recordDate])
  @@index([recordType, status])
  @@index([deletedAt])
  @@map("project_process_records")
}

model ProjectPayment {
  id                      String    @id @default(uuid())
  projectId               String    @map("project_id") @db.VarChar(36)
  paymentName             String    @map("payment_name") @db.VarChar(200)
  paymentType             String    @default("Milestone") @map("payment_type") @db.VarChar(30)
  dueDate                 DateTime? @map("due_date")
  receivedDate            DateTime? @map("received_date")
  status                  String    @default("Planned") @db.VarChar(30)
  originalAmount          Decimal   @map("original_amount") @db.Decimal(18, 2)
  originalCurrency        String    @map("original_currency") @db.VarChar(10)
  exchangeRate            Decimal   @map("exchange_rate") @db.Decimal(18, 8)
  convertedCurrency       String    @map("converted_currency") @db.VarChar(10)
  convertedAmount         Decimal   @map("converted_amount") @db.Decimal(18, 2)
  receivedOriginalAmount  Decimal   @default(0) @map("received_original_amount") @db.Decimal(18, 2)
  receivedConvertedAmount Decimal   @default(0) @map("received_converted_amount") @db.Decimal(18, 2)
  rateDate                DateTime  @map("rate_date")
  rateSource              String    @map("rate_source") @db.VarChar(50)
  remark                  String?   @db.VarChar(500)
  createdBy               String    @map("created_by") @db.VarChar(36)
  deletedAt               DateTime? @map("deleted_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])

  @@index([projectId, status])
  @@index([dueDate])
  @@index([deletedAt])
  @@map("project_payments")
}

// ============================================================
// 03 — 档案模板 + 项目档案
// ============================================================

model ArchiveTemplate {
  id                        String   @id @default(uuid())
  templateCode              String   @unique @map("template_code") @db.VarChar(50)
  templateName              String   @map("template_name") @db.VarChar(100)
  projectType               String?  @map("project_type") @db.VarChar(50)
  countryCode               String?  @map("country_code") @db.VarChar(10)
  languageCode              String?  @map("language_code") @db.VarChar(10)
  version                   String   @default("V1.0") @db.VarChar(10)
  status                    String   @default("DRAFT") @db.VarChar(20)
  description               String?  @db.Text
  createdBy                 String?  @map("created_by") @db.VarChar(36)
  updatedBy                 String?  @map("updated_by") @db.VarChar(36)
  currentPublishedVersionId String?  @unique @map("current_published_version_id") @db.VarChar(36)
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  items                   ArchiveTemplateItem[]
  creator                 User?                    @relation("ArchiveTemplateCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  updater                 User?                    @relation("ArchiveTemplateUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  versions                ArchiveTemplateVersion[] @relation("ArchiveTemplateVersions")
  currentPublishedVersion ArchiveTemplateVersion?  @relation("ArchiveTemplateCurrentPublishedVersion", fields: [currentPublishedVersionId], references: [id], onDelete: SetNull)
  projectSnapshots        Project[]                @relation("ProjectArchiveTemplateSnapshot")

  @@index([projectType, countryCode])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([status])
  @@map("archive_templates")
}

/// Versioned two-level archive templates. Historical ArchiveTemplateItem rows
/// are migration sources only; published versions here are immutable snapshots.
model ArchiveTemplateVersion {
  id              String    @id @default(uuid()) @db.VarChar(36)
  templateId      String    @map("template_id") @db.VarChar(36)
  versionNo       String    @map("version_no") @db.VarChar(20)
  status          String    @default("DRAFT") @db.VarChar(20)
  revision        Int       @default(1)
  sourceVersionId String?   @map("source_version_id") @db.VarChar(36)
  submittedAt     DateTime? @map("submitted_at")
  publishedAt     DateTime? @map("published_at")
  publishedBy     String?   @map("published_by") @db.VarChar(36)
  createdBy       String?   @map("created_by") @db.VarChar(36)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  template           ArchiveTemplate              @relation("ArchiveTemplateVersions", fields: [templateId], references: [id], onDelete: Cascade)
  sourceVersion      ArchiveTemplateVersion?      @relation("ArchiveTemplateVersionLineage", fields: [sourceVersionId], references: [id], onDelete: SetNull)
  derivedVersions    ArchiveTemplateVersion[]     @relation("ArchiveTemplateVersionLineage")
  currentForTemplate ArchiveTemplate?             @relation("ArchiveTemplateCurrentPublishedVersion")
  folders            ArchiveTemplateFolder[]
  versionItems       ArchiveTemplateVersionItem[]
  projectSnapshots   Project[]                    @relation("ProjectArchiveTemplateVersionSnapshot")
  projectEntries     ProjectArchiveEntry[]

  @@unique([templateId, versionNo])
  @@index([templateId, status])
  @@map("archive_template_versions")
}

model ArchiveTemplateFolder {
  id                String   @id @default(uuid()) @db.VarChar(36)
  templateVersionId String   @map("template_version_id") @db.VarChar(36)
  stableKey         String   @map("stable_key") @db.VarChar(100)
  name              String   @db.VarChar(200)
  description       String?  @db.Text
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  templateVersion ArchiveTemplateVersion       @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  items           ArchiveTemplateVersionItem[]
  projectFolders  ProjectArchiveFolder[]

  @@unique([templateVersionId, stableKey], map: "archive_template_folders_template_version_id_stable_key_key")
  @@index([templateVersionId, sortOrder])
  @@map("archive_template_folders")
}

model ArchiveTemplateVersionItem {
  id                 String   @id @default(uuid()) @db.VarChar(36)
  templateVersionId  String   @map("template_version_id") @db.VarChar(36)
  folderId           String   @map("folder_id") @db.VarChar(36)
  stableKey          String   @map("stable_key") @db.VarChar(100)
  name               String   @db.VarChar(200)
  description        String?  @db.Text
  required           Boolean  @default(true)
  reviewRequired     Boolean  @default(false) @map("review_required")
  approvalTemplateId String?  @map("approval_template_id") @db.VarChar(36)
  ownerRoleId        String?  @map("owner_role_id") @db.VarChar(36)
  allowMultipleFiles Boolean  @default(false) @map("allow_multiple_files")
  allowedExtensions  Json?    @map("allowed_extensions")
  maxFileSize        BigInt?  @map("max_file_size")
  namingRule         String?  @map("naming_rule") @db.VarChar(500)
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  templateVersion ArchiveTemplateVersion @relation(fields: [templateVersionId], references: [id], onDelete: Cascade)
  folder          ArchiveTemplateFolder  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  projectEntries  ProjectArchiveEntry[]

  @@unique([templateVersionId, stableKey], map: "atv_items_version_stable_key_uq")
  @@index([folderId, sortOrder])
  @@map("archive_template_version_items")
}

model ArchiveTemplateItem {
  id               String   @id @default(uuid())
  templateId       String   @map("template_id") @db.VarChar(36)
  parentId         String?  @map("parent_id") @db.VarChar(36)
  stageCode        String   @map("stage_code") @db.VarChar(30)
  itemNo           Int      @map("item_no")
  level            Int      @default(1)
  name             String   @db.VarChar(200)
  secondName       String?  @map("second_name") @db.VarChar(200)
  usageDescription String?  @map("usage_description") @db.Text
  isRequired       Boolean  @default(true) @map("is_required")
  isStar           Boolean  @default(false) @map("is_star")
  isSensitive      Boolean  @default(false) @map("is_sensitive")
  needReview       Boolean  @default(false) @map("need_review")
  responsibleRole  String?  @map("responsible_role") @db.VarChar(50)
  reviewRole       String?  @map("review_role") @db.VarChar(50)
  allowedFileTypes String?  @map("allowed_file_types") @db.VarChar(200)
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  template            ArchiveTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parent              ArchiveTemplateItem?  @relation("ArchiveItemHierarchy", fields: [parentId], references: [id])
  children            ArchiveTemplateItem[] @relation("ArchiveItemHierarchy")
  projectArchiveItems ProjectArchiveItem[]

  @@index([templateId])
  @@index([stageCode])
  @@map("archive_template_items")
}

model ProjectArchiveItem {
  id                String            @id @default(uuid())
  projectId         String            @map("project_id") @db.VarChar(36)
  templateItemId    String            @map("template_item_id") @db.VarChar(36)
  parentId          String?           @map("parent_id") @db.VarChar(36)
  stageCode         String            @map("stage_code") @db.VarChar(30)
  itemNo            Int               @map("item_no")
  level             Int               @default(1)
  name              String            @db.VarChar(200)
  secondName        String?           @map("second_name") @db.VarChar(200)
  usageDescription  String?           @map("usage_description") @db.Text
  isRequired        Boolean           @default(true) @map("is_required")
  isStar            Boolean           @default(false) @map("is_star")
  isSensitive       Boolean           @default(false) @map("is_sensitive")
  needReview        Boolean           @default(false) @map("need_review")
  responsibleUserId String?           @map("responsible_user_id") @db.VarChar(36)
  reviewUserId      String?           @map("review_user_id") @db.VarChar(36)
  status            ArchiveItemStatus @default(NotStarted) @map("status")
  dueDate           DateTime?         @map("due_date")
  completedAt       DateTime?         @map("completed_at")
  sortOrder         Int               @default(0) @map("sort_order")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateItem    ArchiveTemplateItem  @relation(fields: [templateItemId], references: [id])
  responsibleUser User?                @relation("ArchiveResponsibleUser", fields: [responsibleUserId], references: [id])
  reviewUser      User?                @relation("ArchiveReviewUser", fields: [reviewUserId], references: [id])
  parent          ProjectArchiveItem?  @relation("ProjectArchiveHierarchy", fields: [parentId], references: [id])
  children        ProjectArchiveItem[] @relation("ProjectArchiveHierarchy")
  files           File[]

  @@index([projectId])
  @@index([stageCode])
  @@index([status])
  @@map("project_archive_items")
}

/// Target two-level project archive snapshot. Legacy ProjectArchiveItem rows
/// are migrated only after structural validation; both models coexist until
/// the compatibility read path is retired.
model ProjectArchiveFolder {
  id                     String    @id @default(uuid()) @db.VarChar(36)
  projectId              String    @map("project_id") @db.VarChar(36)
  name                   String    @db.VarChar(200)
  description            String?   @db.Text
  sortOrder              Int       @default(0) @map("sort_order")
  sourceTemplateFolderId String?   @map("source_template_folder_id") @db.VarChar(36)
  sourceStableKey        String?   @map("source_stable_key") @db.VarChar(100)
  isTemporary            Boolean   @default(false) @map("is_temporary")
  archivedAt             DateTime? @map("archived_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  project              Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceTemplateFolder ArchiveTemplateFolder? @relation(fields: [sourceTemplateFolderId], references: [id], onDelete: SetNull)
  items                ProjectArchiveEntry[]

  @@unique([projectId, sourceStableKey])
  @@index([projectId, sortOrder])
  @@index([archivedAt])
  @@map("project_archive_folders")
}

model ProjectArchiveEntry {
  id                   String    @id @default(uuid()) @db.VarChar(36)
  projectId            String    @map("project_id") @db.VarChar(36)
  folderId             String    @map("folder_id") @db.VarChar(36)
  templateVersionId    String?   @map("template_version_id") @db.VarChar(36)
  sourceTemplateItemId String?   @map("source_template_item_id") @db.VarChar(36)
  sourceStableKey      String?   @map("source_stable_key") @db.VarChar(100)
  name                 String    @db.VarChar(200)
  description          String?   @db.Text
  required             Boolean   @default(true)
  reviewRequired       Boolean   @default(false) @map("review_required")
  approvalTemplateId   String?   @map("approval_template_id") @db.VarChar(36)
  ownerUserId          String?   @map("owner_user_id") @db.VarChar(36)
  ownerRoleId          String?   @map("owner_role_id") @db.VarChar(36)
  allowMultipleFiles   Boolean   @default(false) @map("allow_multiple_files")
  allowedExtensions    Json?     @map("allowed_extensions")
  maxFileSize          BigInt?   @map("max_file_size")
  namingRule           String?   @map("naming_rule") @db.VarChar(500)
  sortOrder            Int       @default(0) @map("sort_order")
  isTemporary          Boolean   @default(false) @map("is_temporary")
  temporaryReason      String?   @map("temporary_reason") @db.VarChar(500)
  suggestedForTemplate Boolean   @default(false) @map("suggested_for_template")
  archivedAt           DateTime? @map("archived_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  project            Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder             ProjectArchiveFolder        @relation(fields: [folderId], references: [id], onDelete: Cascade)
  templateVersion    ArchiveTemplateVersion?     @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  sourceTemplateItem ArchiveTemplateVersionItem? @relation(fields: [sourceTemplateItemId], references: [id], onDelete: SetNull)
  ownerUser          User?                       @relation("ProjectArchiveEntryOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  files              ProjectArchiveFile[]

  @@unique([projectId, templateVersionId, sourceStableKey], map: "project_archive_entries_project_version_stable_uq")
  @@index([projectId, folderId, sortOrder])
  @@index([ownerUserId])
  @@index([archivedAt])
  @@map("project_archive_entries")
}

model ProjectArchiveFile {
  id            String    @id @default(uuid()) @db.VarChar(36)
  projectId     String    @map("project_id") @db.VarChar(36)
  archiveItemId String    @map("archive_item_id") @db.VarChar(36)
  logicalFileId String    @unique @map("logical_file_id") @db.VarChar(36)
  status        String    @default("DRAFT") @db.VarChar(20)
  createdBy     String    @map("created_by") @db.VarChar(36)
  archivedAt    DateTime? @map("archived_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  archiveItem ProjectArchiveEntry @relation(fields: [archiveItemId], references: [id], onDelete: Cascade)
  logicalFile LogicalFile         @relation(fields: [logicalFileId], references: [id], onDelete: Restrict)

  @@index([projectId, archiveItemId])
  @@index([status])
  @@index([archivedAt])
  @@map("project_archive_files")
}

enum ArchiveItemStatus {
  NotStarted
  PendingUpload
  Uploaded
  Reviewing
  Approved
  Rejected
  NotApplicable
  Archived
}

// ============================================================
// 04 — 文件与版本管理
// ============================================================

model File {
  id              String     @id @default(uuid())
  projectId       String     @map("project_id") @db.VarChar(36)
  archiveItemId   String?    @map("archive_item_id") @db.VarChar(36)
  fileName        String     @map("file_name") @db.VarChar(255)
  originalName    String     @map("original_name") @db.VarChar(255)
  fileExt         String     @map("file_ext") @db.VarChar(20)
  fileSize        BigInt     @map("file_size")
  mimeType        String     @map("mime_type") @db.VarChar(100)
  storageProvider String     @default("minio") @map("storage_provider") @db.VarChar(20)
  storageBucket   String     @default("delivery-platform") @map("storage_bucket") @db.VarChar(100)
  storagePath     String     @map("storage_path") @db.VarChar(500)
  versionNo       String     @default("V1.0") @map("version_no") @db.VarChar(10)
  isCurrent       Boolean    @default(true) @map("is_current")
  fileStatus      FileStatus @default(Uploaded) @map("file_status")
  uploadUserId    String     @map("upload_user_id") @db.VarChar(36)
  uploadTime      DateTime   @default(now()) @map("upload_time")
  remark          String?    @db.Text
  deletedAt       DateTime?  @map("deleted_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  project     Project             @relation(fields: [projectId], references: [id])
  archiveItem ProjectArchiveItem? @relation(fields: [archiveItemId], references: [id])
  uploadUser  User                @relation(fields: [uploadUserId], references: [id])
  reviews     FileReview[]

  @@index([projectId])
  @@index([archiveItemId])
  @@index([fileStatus])
  @@index([deletedAt])
  @@map("files")
}

enum FileStatus {
  Draft
  Uploaded
  Reviewing
  Approved
  Rejected
  Deprecated
  Archived
}

model FileReview {
  id            String   @id @default(uuid())
  fileId        String   @map("file_id") @db.VarChar(36)
  archiveItemId String   @map("archive_item_id") @db.VarChar(36)
  reviewUserId  String   @map("review_user_id") @db.VarChar(36)
  reviewStatus  String   @map("review_status") @db.VarChar(20)
  reviewComment String?  @map("review_comment") @db.Text
  reviewTime    DateTime @default(now()) @map("review_time")
  createdAt     DateTime @default(now()) @map("created_at")

  file     File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  reviewer User @relation(fields: [reviewUserId], references: [id])

  @@index([fileId])
  @@map("file_reviews")
}

/// A logical file owns the immutable version history. FileAsset stores one
/// physical object only; binary data remains in MinIO-compatible storage.
model LogicalFile {
  id               String    @id @default(uuid()) @db.VarChar(36)
  ownerType        String    @map("owner_type") @db.VarChar(50)
  ownerId          String    @map("owner_id") @db.VarChar(36)
  displayName      String    @map("display_name") @db.VarChar(255)
  currentVersionId String?   @unique @map("current_version_id") @db.VarChar(36)
  status           String    @default("DRAFT") @db.VarChar(20)
  createdBy        String    @map("created_by") @db.VarChar(36)
  archivedAt       DateTime? @map("archived_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  creator            User                @relation("LogicalFileCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  versions           FileVersion[]       @relation("LogicalFileVersions")
  currentVersion     FileVersion?        @relation("LogicalFileCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  projectArchiveFile ProjectArchiveFile?

  @@index([ownerType, ownerId])
  @@index([status])
  @@index([archivedAt])
  @@map("logical_files")
}

model FileAsset {
  id              String    @id @default(uuid()) @db.VarChar(36)
  ownerType       String    @map("owner_type") @db.VarChar(50)
  ownerId         String    @map("owner_id") @db.VarChar(36)
  originalName    String    @map("original_name") @db.VarChar(255)
  extension       String?   @db.VarChar(20)
  mimeType        String    @map("mime_type") @db.VarChar(100)
  size            BigInt
  storageProvider String    @default("minio") @map("storage_provider") @db.VarChar(20)
  storageBucket   String    @map("storage_bucket") @db.VarChar(100)
  storageKey      String    @map("storage_key") @db.VarChar(500)
  checksum        String?   @db.VarChar(128)
  status          String    @default("AVAILABLE") @db.VarChar(20)
  createdBy       String    @map("created_by") @db.VarChar(36)
  archivedAt      DateTime? @map("archived_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  creator           User                @relation("FileAssetCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  versions          FileVersion[]
  processingInputs  FileProcessingJob[] @relation("FileProcessingInput")
  processingOutputs FileProcessingJob[] @relation("FileProcessingOutput")

  @@unique([storageBucket, storageKey])
  @@index([ownerType, ownerId])
  @@index([status])
  @@index([archivedAt])
  @@map("file_assets")
}

model FileVersion {
  id                String    @id @default(uuid()) @db.VarChar(36)
  idempotencyKey    String?   @unique @map("idempotency_key") @db.VarChar(100)
  logicalFileId     String    @map("logical_file_id") @db.VarChar(36)
  version           String    @db.VarChar(20)
  versionSequence   Int       @map("version_sequence")
  revisionLevel     String    @default("MINOR") @map("revision_level") @db.VarChar(20)
  assetId           String    @map("asset_id") @db.VarChar(36)
  status            String    @default("UPLOADED") @db.VarChar(20)
  changeDescription String?   @map("change_description") @db.VarChar(1000)
  uploadedBy        String    @map("uploaded_by") @db.VarChar(36)
  uploadedAt        DateTime  @default(now()) @map("uploaded_at")
  approvedAt        DateTime? @map("approved_at")
  archivedAt        DateTime? @map("archived_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  logicalFile           LogicalFile            @relation("LogicalFileVersions", fields: [logicalFileId], references: [id], onDelete: Cascade)
  currentForLogicalFile LogicalFile?           @relation("LogicalFileCurrentVersion")
  asset                 FileAsset              @relation(fields: [assetId], references: [id], onDelete: Restrict)
  uploader              User                   @relation("FileVersionUploader", fields: [uploadedBy], references: [id], onDelete: Restrict)
  reviewTasks           ReviewTask[]
  standardVersions      StandardVersion[]
  knowledgeVersionsV2   KnowledgeVersion[]
  knowledgeVersionFiles KnowledgeVersionFile[]

  @@unique([logicalFileId, versionSequence])
  @@unique([logicalFileId, version])
  @@index([assetId])
  @@index([status])
  @@map("file_versions")
}

model FileProcessingJob {
  id             String    @id @default(uuid()) @db.VarChar(36)
  fileAssetId    String    @map("file_asset_id") @db.VarChar(36)
  type           String    @db.VarChar(30)
  status         String    @default("PENDING") @db.VarChar(20)
  progress       Int       @default(0)
  attempts       Int       @default(0)
  availableAt    DateTime  @default(now()) @map("available_at")
  leaseOwner     String?   @map("lease_owner") @db.VarChar(100)
  leaseExpiresAt DateTime? @map("lease_expires_at")
  outputAssetId  String?   @map("output_asset_id") @db.VarChar(36)
  errorCode      String?   @map("error_code") @db.VarChar(100)
  errorMessage   String?   @map("error_message") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  inputAsset  FileAsset  @relation("FileProcessingInput", fields: [fileAssetId], references: [id], onDelete: Cascade)
  outputAsset FileAsset? @relation("FileProcessingOutput", fields: [outputAssetId], references: [id], onDelete: SetNull)

  @@index([fileAssetId, type, status])
  @@index([status, availableAt, createdAt], map: "file_processing_jobs_status_available_created_idx")
  @@index([status, leaseExpiresAt], map: "file_processing_jobs_status_lease_expires_idx")
  @@map("file_processing_jobs")
}

/// Unified review workflow. Approval configuration is snapshotted at task
/// creation so later configuration edits cannot change an in-flight review.
model ReviewTask {
  id                      String    @id @default(uuid()) @db.VarChar(36)
  activeReviewKey         String?   @unique(map: "review_tasks_active_review_key_key") @map("active_review_key") @db.VarChar(160)
  sourceType              String    @map("source_type") @db.VarChar(30)
  sourceId                String    @map("source_id") @db.VarChar(36)
  sourceVersionId         String?   @map("source_version_id") @db.VarChar(36)
  projectId               String?   @map("project_id") @db.VarChar(36)
  fileVersionId           String?   @map("file_version_id") @db.VarChar(36)
  approvalTemplateId      String?   @map("approval_template_id") @db.VarChar(36)
  approvalTemplateVersion String?   @map("approval_template_version") @db.VarChar(30)
  approvalSnapshot        Json?     @map("approval_snapshot")
  title                   String    @db.VarChar(255)
  locationLabel           String?   @map("location_label") @db.VarChar(500)
  status                  String    @default("PENDING") @db.VarChar(20)
  reviewMode              String    @default("SINGLE") @map("review_mode") @db.VarChar(20)
  currentStepNo           Int       @default(1) @map("current_step_no")
  totalSteps              Int       @default(1) @map("total_steps")
  submittedBy             String    @map("submitted_by") @db.VarChar(36)
  submittedAt             DateTime  @default(now()) @map("submitted_at")
  completedAt             DateTime? @map("completed_at")
  dueAt                   DateTime? @map("due_at")
  archivedAt              DateTime? @map("archived_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  project      Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  fileVersion  FileVersion?        @relation(fields: [fileVersionId], references: [id], onDelete: SetNull)
  submitter    User                @relation("ReviewTaskSubmitter", fields: [submittedBy], references: [id], onDelete: Restrict)
  steps        ReviewStep[]
  actionEvents ReviewActionEvent[]

  @@index([sourceType, sourceId])
  @@index([projectId, status])
  @@index([fileVersionId])
  @@index([submittedBy, status])
  @@index([status, submittedAt])
  @@map("review_tasks")
}

model ReviewStep {
  id                    String    @id @default(uuid()) @db.VarChar(36)
  reviewTaskId          String    @map("review_task_id") @db.VarChar(36)
  stepNo                Int       @map("step_no")
  mode                  String    @default("SINGLE") @db.VarChar(20)
  requiredCount         Int       @default(1) @map("required_count")
  status                String    @default("WAITING") @db.VarChar(20)
  configurationSnapshot Json?     @map("configuration_snapshot")
  startedAt             DateTime? @map("started_at")
  completedAt           DateTime? @map("completed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  reviewTask ReviewTask       @relation(fields: [reviewTaskId], references: [id], onDelete: Cascade)
  assignees  ReviewAssignee[]

  @@unique([reviewTaskId, stepNo])
  @@index([status])
  @@map("review_steps")
}

model ReviewAssignee {
  id                 String    @id @default(uuid()) @db.VarChar(36)
  reviewStepId       String    @map("review_step_id") @db.VarChar(36)
  assigneeUserId     String    @map("assignee_user_id") @db.VarChar(36)
  resolvedFromType   String?   @map("resolved_from_type") @db.VarChar(30)
  resolvedFromValue  String?   @map("resolved_from_value") @db.VarChar(100)
  status             String    @default("PENDING") @db.VarChar(20)
  decision           String?   @db.VarChar(20)
  actedAt            DateTime? @map("acted_at")
  comment            String?   @db.Text
  resolutionMetadata Json?     @map("resolution_metadata")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  reviewStep ReviewStep @relation(fields: [reviewStepId], references: [id], onDelete: Cascade)
  assignee   User       @relation("ReviewAssigneeUser", fields: [assigneeUserId], references: [id], onDelete: Restrict)

  @@unique([reviewStepId, assigneeUserId])
  @@index([assigneeUserId, status])
  @@map("review_assignees")
}

model ReviewActionEvent {
  id           String   @id @default(uuid()) @db.VarChar(36)
  reviewTaskId String   @map("review_task_id") @db.VarChar(36)
  stepNo       Int?     @map("step_no")
  actorUserId  String   @map("actor_user_id") @db.VarChar(36)
  action       String   @db.VarChar(30)
  comment      String?  @db.Text
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  reviewTask ReviewTask @relation(fields: [reviewTaskId], references: [id], onDelete: Cascade)
  actor      User       @relation("ReviewActionActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([reviewTaskId, createdAt])
  @@index([actorUserId])
  @@map("review_action_events")
}

model MigrationException {
  id         String    @id @default(uuid()) @db.VarChar(36)
  domain     String    @db.VarChar(50)
  entityType String    @map("entity_type") @db.VarChar(50)
  entityId   String    @map("entity_id") @db.VarChar(100)
  code       String    @db.VarChar(100)
  details    Json?
  status     String    @default("OPEN") @db.VarChar(20)
  resolvedBy String?   @map("resolved_by") @db.VarChar(36)
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([domain, entityType, entityId, code])
  @@index([domain, status])
  @@index([domain, code, status], map: "migration_exceptions_domain_code_status_idx")
  @@map("migration_exceptions")
}

model OutboxEvent {
  id               String    @id @default(uuid()) @db.VarChar(36)
  eventType        String    @map("event_type") @db.VarChar(100)
  aggregateType    String    @map("aggregate_type") @db.VarChar(50)
  aggregateId      String    @map("aggregate_id") @db.VarChar(36)
  payload          Json
  deduplicationKey String?   @unique @map("deduplication_key") @db.VarChar(200)
  status           String    @default("PENDING") @db.VarChar(20)
  availableAt      DateTime  @default(now()) @map("available_at")
  attempts         Int       @default(0)
  lastError        String?   @map("last_error") @db.Text
  processedAt      DateTime? @map("processed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  notificationDeliveries NotificationDelivery[]

  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events")
}

// ============================================================
// 05 — 检查项
// ============================================================

model ChecklistTemplate {
  id           String   @id @default(uuid())
  templateCode String   @unique @map("template_code") @db.VarChar(50)
  templateName String   @map("template_name") @db.VarChar(100)
  countryCode  String?  @map("country_code") @db.VarChar(10)
  projectType  String?  @map("project_type") @db.VarChar(50)
  stageCode    String?  @map("stage_code") @db.VarChar(30)
  version      String   @default("V1.0") @db.VarChar(10)
  status       String   @default("Active") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  items ChecklistTemplateItem[]

  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id                           String   @id @default(uuid())
  templateId                   String   @map("template_id") @db.VarChar(36)
  itemName                     String   @map("item_name") @db.VarChar(200)
  itemDescription              String?  @map("item_description") @db.Text
  checkStandard                String?  @map("check_standard") @db.Text
  evidenceRequired             String?  @map("evidence_required") @db.Text
  relatedArchiveTemplateItemId String?  @map("related_archive_template_item_id") @db.VarChar(36)
  isRequired                   Boolean  @default(true) @map("is_required")
  riskLevel                    String   @default("Low") @map("risk_level") @db.VarChar(20)
  responsibleRole              String?  @map("responsible_role") @db.VarChar(50)
  reviewRole                   String?  @map("review_role") @db.VarChar(50)
  evidenceTypes                String   @default("photo,file") @map("evidence_types") @db.VarChar(100)
  minEvidenceCount             Int      @default(0) @map("min_evidence_count")
  allowAlbum                   Boolean  @default(true) @map("allow_album")
  requireLocation              Boolean  @default(false) @map("require_location")
  sortOrder                    Int      @default(0) @map("sort_order")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  template              ChecklistTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  projectChecklistItems ProjectChecklistItem[]

  @@index([templateId])
  @@map("checklist_template_items")
}

model ProjectChecklistItem {
  id                   String              @id @default(uuid())
  projectId            String              @map("project_id") @db.VarChar(36)
  templateItemId       String              @map("template_item_id") @db.VarChar(36)
  relatedArchiveItemId String?             @map("related_archive_item_id") @db.VarChar(36)
  itemName             String              @map("item_name") @db.VarChar(200)
  checkStandard        String?             @map("check_standard") @db.Text
  evidenceRequired     String?             @map("evidence_required") @db.Text
  responsibleUserId    String?             @map("responsible_user_id") @db.VarChar(36)
  reviewUserId         String?             @map("review_user_id") @db.VarChar(36)
  status               ChecklistItemStatus @default(Pending) @map("status")
  dueDate              DateTime?           @map("due_date")
  completedAt          DateTime?           @map("completed_at")
  result               String?             @db.VarChar(30)
  resultNote           String?             @map("result_note") @db.Text
  submittedAt          DateTime?           @map("submitted_at")
  reviewedAt           DateTime?           @map("reviewed_at")
  reviewComment        String?             @map("review_comment") @db.Text
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateItem    ChecklistTemplateItem @relation(fields: [templateItemId], references: [id])
  responsibleUser User?                 @relation("ChecklistResponsibleUser", fields: [responsibleUserId], references: [id])
  reviewUser      User?                 @relation("ChecklistReviewUser", fields: [reviewUserId], references: [id])

  @@index([projectId])
  @@index([status])
  @@map("project_checklist_items")
}

enum ChecklistItemStatus {
  Pending
  Processing
  Submitted
  Reviewing
  Approved
  Rejected
  Closed
  NotApplicable
}

// ============================================================
// 06 — 流程标准
// ============================================================

/// Target standard library. Legacy workflow/checklist/document-template rows
/// remain intact until audited, idempotent migration creates version snapshots.
model Standard {
  id                        String    @id @default(uuid()) @db.VarChar(36)
  code                      String    @unique @db.VarChar(50)
  name                      String    @db.VarChar(200)
  type                      String    @db.VarChar(50)
  category                  String?   @db.VarChar(100)
  status                    String    @default("DRAFT") @db.VarChar(20)
  currentPublishedVersionId String?   @unique @map("current_published_version_id") @db.VarChar(36)
  effectiveAt               DateTime? @map("effective_at")
  createdBy                 String    @map("created_by") @db.VarChar(36)
  updatedBy                 String    @map("updated_by") @db.VarChar(36)
  archivedAt                DateTime? @map("archived_at")
  createdAt                 DateTime  @default(now()) @map("created_at")
