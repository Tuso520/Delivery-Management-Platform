model DictionaryItem {
  id         String   @id @default(uuid())
  categoryId String   @map("category_id") @db.VarChar(36)
  itemValue  String   @map("item_value") @db.VarChar(100)
  itemLabel  String   @map("item_label") @db.VarChar(100)
  extraData  Json?    @map("extra_data")
