  departmentName String   @map("department_name") @db.VarChar(100)
  parentId       String?  @map("parent_id") @db.VarChar(36)
  managerId      String?  @map("manager_id") @db.VarChar(36)
  status         String   @default("Active") @db.VarChar(20)
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentHierarchy")
  manager  User?        @relation("DepartmentManager", fields: [managerId], references: [id])
  users    User[]

  @@index([parentId])
  @@map("departments")
}

// ============================================================
// 19 — 审批、技能、培训与复盘
// ============================================================

model ApprovalTemplate {
  id           String   @id @default(uuid())
  templateCode String   @unique @map("template_code") @db.VarChar(50)
  templateName String   @map("template_name") @db.VarChar(100)
  businessType String   @map("business_type") @db.VarChar(50)
  countryCode  String?  @map("country_code") @db.VarChar(10)
  isEnabled    Boolean  @default(true) @map("is_enabled")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  steps ApprovalStep[]
  tasks ApprovalTask[]

  @@index([businessType, isEnabled])
  @@map("approval_templates")
}

model ApprovalStep {
  id            String   @id @default(uuid())
  templateId    String   @map("template_id") @db.VarChar(36)
  stepOrder     Int      @map("step_order")
  stepName      String   @map("step_name") @db.VarChar(100)
  approverType  String   @map("approver_type") @db.VarChar(30)
  approverValue String   @map("approver_value") @db.VarChar(100)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  template ApprovalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, stepOrder])
  @@map("approval_steps")
}

model ApprovalTask {
  id            String    @id @default(uuid())
  templateId    String    @map("template_id") @db.VarChar(36)
  businessType  String    @map("business_type") @db.VarChar(50)
  businessId    String    @map("business_id") @db.VarChar(36)
  businessTitle String?   @map("business_title") @db.VarChar(200)
  applicantId   String    @map("applicant_id") @db.VarChar(36)
  currentStep   Int       @default(1) @map("current_step")
  approverId    String?   @map("approver_id") @db.VarChar(36)
  status        String    @default("Pending") @db.VarChar(20)
  comment       String?   @db.VarChar(500)
  decidedAt     DateTime? @map("decided_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  template  ApprovalTemplate @relation(fields: [templateId], references: [id])
  applicant User             @relation("ApprovalTaskApplicant", fields: [applicantId], references: [id])
  approver  User?            @relation("ApprovalTaskApprover", fields: [approverId], references: [id])
  actions   ApprovalAction[]

  @@index([businessType, businessId])
  @@index([approverId, status])
  @@map("approval_tasks")
}

model ApprovalAction {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id") @db.VarChar(36)
  stepOrder Int      @map("step_order")
  action    String   @db.VarChar(30)
  actorId   String   @map("actor_id") @db.VarChar(36)
  comment   String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  task  ApprovalTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User         @relation(fields: [actorId], references: [id])

  @@index([taskId, createdAt])
  @@map("approval_actions")
}

model SkillDefinition {
  id          String   @id @default(uuid())
  skillCode   String   @unique @map("skill_code") @db.VarChar(50)
  skillName   String   @map("skill_name") @db.VarChar(100)
  category    String   @db.VarChar(50)
  description String?  @db.VarChar(500)
  maxLevel    Int      @default(5) @map("max_level")
  status      String   @default("Active") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  assessments SkillAssessment[]

  @@map("skill_definitions")
}

model SkillAssessment {
  id           String   @id @default(uuid())
  skillId      String   @map("skill_id") @db.VarChar(36)
  userId       String   @map("user_id") @db.VarChar(36)
  assessorId   String   @map("assessor_id") @db.VarChar(36)
  level        Int
  selfScore    Int?     @map("self_score")
  managerScore Int?     @map("manager_score")
  finalScore   Int?     @map("final_score")
  period       String   @db.VarChar(20)
  evidenceNote String?  @map("evidence_note") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  skill    SkillDefinition @relation(fields: [skillId], references: [id])
  user     User            @relation("SkillAssessmentUser", fields: [userId], references: [id])
  assessor User            @relation("SkillAssessmentAssessor", fields: [assessorId], references: [id])

  @@unique([skillId, userId, period])
  @@index([userId, period])
  @@map("skill_assessments")
}

model TrainingPlan {
  id          String    @id @default(uuid())
  title       String    @db.VarChar(200)
  category    String    @db.VarChar(50)
  trainerName String?   @map("trainer_name") @db.VarChar(100)
  trainerId   String?   @map("trainer_id") @db.VarChar(36)
  startAt     DateTime  @map("start_at")
  endAt       DateTime? @map("end_at")
  location    String?   @db.VarChar(200)
  status      String    @default("Planned") @db.VarChar(20)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  participants TrainingParticipant[]
  trainer      User?                 @relation("TrainingTrainer", fields: [trainerId], references: [id])

  @@index([startAt, status])
  @@index([trainerId])
  @@map("training_plans")
}

model TrainingParticipant {
  id          String    @id @default(uuid())
  trainingId  String    @map("training_id") @db.VarChar(36)
  userId      String    @map("user_id") @db.VarChar(36)
  attendance  String    @default("Invited") @db.VarChar(20)
  signedAt    DateTime? @map("signed_at")
  score       Int?
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  training TrainingPlan @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id])

  @@unique([trainingId, userId])
  @@map("training_participants")
}

model ProjectRetrospective {
  id              String   @id @default(uuid())
  projectId       String   @map("project_id") @db.VarChar(36)
  summary         String   @db.Text
  lessonsLearned  String?  @map("lessons_learned") @db.Text
  problemCategory String?  @map("problem_category") @db.VarChar(50)
  status          String   @default("Draft") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project Project               @relation(fields: [projectId], references: [id])
  actions RetrospectiveAction[]

  @@index([projectId, status])
  @@map("project_retrospectives")
}

model RetrospectiveAction {
  id               String    @id @default(uuid())
  retrospectiveId  String    @map("retrospective_id") @db.VarChar(36)
  title            String    @db.VarChar(200)
  ownerId          String    @map("owner_id") @db.VarChar(36)
  dueDate          DateTime? @map("due_date")
  status           String    @default("Open") @db.VarChar(20)
  verificationNote String?   @map("verification_note") @db.VarChar(500)
  closedAt         DateTime? @map("closed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  retrospective ProjectRetrospective @relation(fields: [retrospectiveId], references: [id], onDelete: Cascade)
  owner         User                 @relation(fields: [ownerId], references: [id])

  @@index([ownerId, status])
  @@map("retrospective_actions")
}

model BackupRecord {
  id           String    @id @default(uuid())
  backupType   String    @map("backup_type") @db.VarChar(30)
  status       String    @default("Pending") @db.VarChar(20)
  storagePath  String?   @map("storage_path") @db.VarChar(500)
  fileSize     BigInt?   @map("file_size")
  requestedBy  String    @map("requested_by") @db.VarChar(36)
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  errorMessage String?   @map("error_message") @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at")

  requester User @relation(fields: [requestedBy], references: [id])

  @@index([status, createdAt])
  @@map("backup_records")
}
