  version           String    @db.VarChar(20)
  fileVersionId     String?   @map("file_version_id") @db.VarChar(36)
  /// Transitional, read-only migration source. New standard content is file-only;
  /// remove this field only after strict content verification passes in production.
  structuredContent Json?     @map("structured_content")
  /// Transitional, read-only migration source retained during the file backfill.
  applicability     Json?
  /// Transitional audit snapshot; never expose it through public API responses.
  legacySnapshot    Json?     @map("legacy_snapshot")
  status            String    @default("DRAFT") @db.VarChar(20)
  revision          Int       @default(1)
  effectiveAt       DateTime? @map("effective_at")
  changeDescription String?   @map("change_description") @db.VarChar(1000)
  submittedBy       String    @map("submitted_by") @db.VarChar(36)
  submittedAt       DateTime? @map("submitted_at")
  publishedAt       DateTime? @map("published_at")
  archivedAt        DateTime? @map("archived_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  standard           Standard     @relation("StandardVersions", fields: [standardId], references: [id], onDelete: Cascade)
  currentForStandard Standard?    @relation("StandardCurrentPublishedVersion")
  fileVersion        FileVersion? @relation(fields: [fileVersionId], references: [id], onDelete: SetNull)
  submitter          User         @relation("StandardVersionSubmitter", fields: [submittedBy], references: [id], onDelete: Restrict)

  @@unique([standardId, version])
  @@index([standardId, status])
  @@index([fileVersionId])
  @@index([status, archivedAt], map: "standard_versions_status_archived_at_idx")
  @@map("standard_versions")
}

