APP_NAME=delivery-platform
APP_ENV=production
APP_PORT=8080
APP_VERSION=CHANGE_ME_RELEASE_VERSION
RELEASE_ID=CHANGE_ME_RELEASE_ID
COMPOSE_PROJECT_NAME=delivery-platform
DOMAIN=CHANGE_ME_DOMAIN
PUBLIC_URL=http://CHANGE_ME_DOMAIN:8080
API_BASE_URL=http://CHANGE_ME_DOMAIN:8080/api/v1

FRONTEND_PORT=8080
BACKEND_PORT=3000
MYSQL_PORT=3306
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD
MYSQL_DATABASE=delivery_platform
MYSQL_USER=delivery_user
MYSQL_USER_PASSWORD=CHANGE_ME_MYSQL_USER_PASSWORD

REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

MINIO_ROOT_USER=delivery_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=delivery-platform
MINIO_IMAGE=quay.io/minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=quay.io/minio/mc:RELEASE.2025-07-21T05-28-08Z

# Comma-separated explicit browser origins. Production rejects `*` and empty values.
CORS_ORIGIN=http://CHANGE_ME_DOMAIN:8080

DATABASE_URL=mysql://delivery_user:CHANGE_ME_MYSQL_USER_PASSWORD@mysql:3306/delivery_platform
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_WITH_AT_LEAST_32_CHARACTERS
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
REFRESH_COOKIE_NAME=delivery_refresh_token
# 32 random bytes encoded as Base64; never reuse JWT or database credentials.
INTEGRATION_SECRET_ENCRYPTION_KEY=CHANGE_ME_TO_32_RANDOM_BYTES_IN_BASE64
# Active account used only to attribute the one-time encrypted integration migration audit.
INTEGRATION_SECRET_MIGRATION_ACTOR_USERNAME=admin

# Both values are required for signed, read-only Office preview sessions.
ONLYOFFICE_DOCS_URL=
ONLYOFFICE_JWT_SECRET=

# Optional audited conversion service. Keep empty to fail unsupported conversions explicitly.
FILE_CONVERTER_URL=
FILE_CONVERTER_TOKEN=
FILE_CONVERTER_TIMEOUT_MS=120000
FILE_CONVERTER_MAX_OUTPUT_BYTES=209715200
FILE_PROCESSING_MAX_ATTEMPTS=3
FILE_PROCESSING_LEASE_MS=300000
FILE_PROCESSING_RETRY_BASE_MS=5000
FILE_PROCESSING_RETRY_MAX_MS=900000

# Required seed password inputs. CHANGE_ME values are non-usable placeholders
# and are rejected in every runtime environment.
SEED_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
SEED_DEFAULT_PASSWORD=CHANGE_ME_DEMO_USER_PASSWORD
# Existing seed-account passwords are preserved unless an intentional rotation
# explicitly overrides this value.
SEED_RESET_EXISTING_USER_PASSWORDS=false
# Deployment safety ceiling for in-memory multipart parsing (1-1024 MB).
# The editable attachment.max_size_mb setting can only further reduce this limit.
FILE_UPLOAD_HARD_LIMIT_MB=1024
