APP_NAME=delivery-platform
APP_ENV=production
APP_PORT=8080
APP_VERSION=CHANGE_ME_RELEASE_VERSION
RELEASE_ID=CHANGE_ME_RELEASE_ID
COMPOSE_PROJECT_NAME=delivery-platform
DOMAIN=CHANGE_ME_DOMAIN
PUBLIC_URL=http://CHANGE_ME_DOMAIN:8080
API_BASE_URL=http://CHANGE_ME_DOMAIN:8080/api/v1

FRONTEND_PORT=8080
BACKEND_PORT=3000
MYSQL_PORT=3306
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD
MYSQL_DATABASE=delivery_platform
MYSQL_USER=delivery_user
MYSQL_USER_PASSWORD=CHANGE_ME_MYSQL_USER_PASSWORD

REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

MINIO_ROOT_USER=delivery_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=delivery-platform
MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-07-21T05-28-08Z

CORS_ORIGIN=http://CHANGE_ME_DOMAIN:8080

DATABASE_URL=mysql://delivery_user:CHANGE_ME_MYSQL_USER_PASSWORD@mysql:3306/delivery_platform
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_WITH_AT_LEAST_32_CHARACTERS
JWT_EXPIRES_IN=8h

# Only used when seed creates an account that does not already exist.
SEED_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
SEED_DEFAULT_PASSWORD=CHANGE_ME_DEMO_USER_PASSWORD
